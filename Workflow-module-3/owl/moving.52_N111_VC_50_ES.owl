        <ontology:hasDescription>Some Spanish mountain regions carry out mycological exploitation initiatives, with different degrees of importance and regulation. Such is the case in the mountains of León, the sierras of Salamanca and Zamora, as well as the Sierra de Cameros in La Rioja.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N111_VC_50_ES/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N111_VC_50_ES/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
