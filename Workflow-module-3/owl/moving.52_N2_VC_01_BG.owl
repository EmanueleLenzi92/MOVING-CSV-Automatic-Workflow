        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1141462"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1219634"/>
