    <!-- https://dlnarratives.eu/appellation/Winter_sports_(downhill_sking_and_snowboarding)_within_the_Lecht_ski_resort_-_reliant_on_landscape_for_the_slope_and_snow_for_skiing._Uses_a_wind_power_to_run_tehir_snow_making_factory_to_supplement_their_natural_snow_cover._Use_of_the_area_in_summer_as_a_result_of_the_winter_sports_is_also_of_interest._The_Lecht_ski_resort_lies_within_Aberdeenshire_LAU1 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/appellation/Winter_sports_(downhill_sking_and_snowboarding)_within_the_Lecht_ski_resort_-_reliant_on_landscape_for_the_slope_and_snow_for_skiing._Uses_a_wind_power_to_run_tehir_snow_making_factory_to_supplement_their_natural_snow_cover._Use_of_the_area_in_summer_as_a_result_of_the_winter_sports_is_also_of_interest._The_Lecht_ski_resort_lies_within_Aberdeenshire_LAU1">
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Appellation"/>
        <ontology:has_note>Winter sports (downhill sking and snowboarding) within the Lecht ski resort - reliant on landscape for the slope and snow for skiing. Uses a wind power to run tehir snow making factory to supplement their natural snow cover. Use of the area in summer as a result of the winter sports is also of interest. The Lecht ski resort lies within Aberdeenshire LAU1</ontology:has_note>
    </NamedIndividual>
    


