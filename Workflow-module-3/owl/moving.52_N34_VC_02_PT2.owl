    <!-- https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev7 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1165944"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q13439060"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q45"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7368"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q738004"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q738011"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q76872"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q8495"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev8"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Interest_on_this_VC"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.39081646399735_-7.520209808582196"/>
        <ontology:hasDescription>Milk from two autochthonous sheep breeds is used to produce the traditonal Serra da Estrela Cheese, which is the oldest Portuguese cheese and is highly connected to territorial identity. Product with PDO certification. Product highly characteristic of the MRL. Product highly connected to land use and landscape management. Product internationally recognized for its organoleptic characteristics.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev8 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev8">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q10943"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q11254"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q538906"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7186137"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7368"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q8495"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev9"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Key_local_assets"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.39081646399735_-7.520209808582196"/>
        <ontology:hasDescription>Bordaleira Serra da Estrela sheep breed has a medium stature and is white or black in color. It has horns curled forward and females have a well developed udder. It has, predominantly, dairy aptitude. Churra Mondegueira sheep breed is of medium stature and is white in color. Traditional knowledge, passed down from generation to generation, on cheese manufacture techniques from sheep&amp;apos;s milk, salt and thistle (Cynara cardunculus) flower.   </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev9 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev9">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q11663"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1400839"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q81710"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q82821"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2/event/ev10"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Challenges"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N34_VC_02_PT2"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.39081646399735_-7.520209808582196"/>
        <ontology:hasDescription>Reduced number of shepherds, as this job is often seen as unattractive, due to being physically demanding, in sometimes harsh weather conditions, and low wages. Overall the type of challenge faced by this VC is Current and Predicted. This VC is classified as Traditional.  </ontology:hasDescription>
    </NamedIndividual>
    


