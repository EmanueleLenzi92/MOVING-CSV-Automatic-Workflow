        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/51.681421916684215_-3.74173536641693"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The type of innovation of this VC (Value Chain) is unspecified. traditional as windturbines (onshore) are not a new venture. The innovation is related to the whole VC. The land use systems involved are Grassland and Natural land. The local assets include Natural, social and cultural.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N325_VC_18_UK/event/ev11 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N325_VC_18_UK/event/ev11">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
