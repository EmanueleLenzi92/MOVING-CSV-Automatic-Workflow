        <rdfs:comment>This class represents a physical thing. Equivalent to the CRM class E18 Physical Thing.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Place -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Place">
        <rdfs:comment>This class represents a place. Equivalent to the CRM class E53 Place.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Proposition -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Proposition">
        <rdfs:subClassOf rdf:resource="https://dlnarratives.eu/ontology#Entity"/>
        <rdfs:comment>This class represents a proposition endowed with a subject, predicate, and object.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Proposition_Set -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Proposition_Set">
        <rdfs:comment>This class represents a proposition set. Equivalent to the CRMinf class I4 Proposition Set.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Propositional_Object -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Propositional_Object">
        <rdfs:comment>This class represents a propositional object. Equivalent to the CRM class E89 Propositional Object.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Reference_Space -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Reference_Space"/>
    


    <!-- https://dlnarratives.eu/ontology#Role -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Role">
        <rdfs:subClassOf rdf:resource="https://dlnarratives.eu/ontology#Entity"/>
        <rdfs:comment>This class represents a role in the event.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Space_Primitive -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Space_Primitive">
        <rdfs:comment>This class represents a space primitive. Equivalent to the CRM class E94 Space primitive.</rdfs:comment>
    </Class>
    


    <!-- https://dlnarratives.eu/ontology#Spatial_Coordinate_Reference_System -->


    <Class rdf:about="https://dlnarratives.eu/ontology#Spatial_Coordinate_Reference_System">
