        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>Natural asset are forests with wood production function. Social assets are interactions between Slovak foresters and wood processors; and demand of customers for wooden houses.   </ontology:hasDescription>
    </NamedIndividual>
    


