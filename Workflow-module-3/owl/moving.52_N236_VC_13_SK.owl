        <ontology:hasDescription>The MOVING reference member state of this VC (Value Chain) is SLOVAKIA. The reference MOVING Card ID of this VC is VC 13 SK. Activities: hunting, selling, meat processing, accomodation for hunters. Key actors: hunters, consumers, retailers and wholesalers . Positive impact on local and regional SES is an added value to national economy, shorter food chain.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N236_VC_13_SK/event/ev10 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N236_VC_13_SK/event/ev10">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
