        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/48.94259439711003_18.431998357299868"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>Natural assets are forests with wild game. Social asset is a collaboration between hunters, foresters, meat processors and traders. Cultural asset is a tradition of hunting in Slovak mountains.   </ontology:hasDescription>
    </NamedIndividual>
    


