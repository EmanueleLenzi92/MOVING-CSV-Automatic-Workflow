        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q329046"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q354963"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N250_VC_14_PT2/event/ev10"/>
