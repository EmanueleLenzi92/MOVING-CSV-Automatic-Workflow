    <!-- https://dlnarratives.eu/narrative/N250_VC_14_PT2/event/ev7 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N250_VC_14_PT2/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q10987"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1165944"/>
