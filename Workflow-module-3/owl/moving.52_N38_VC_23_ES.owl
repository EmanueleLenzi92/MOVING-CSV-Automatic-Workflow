        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N38_VC_23_ES"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/38.3_-5.4"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Sierra Morena. The reference mountain landscape of this VC is Aroche. It is located in the occidental edge of the Natural Park. The landscape is a mosaic of dehesas and pastures with hilly geography intertwined with forests of holm and cork oaks and chestnuts. It represents an ideal ecosystem for extensive grazers. Consequently, in this MRL, the Iberian pig is also very relevant.  </ontology:hasDescription>
    </NamedIndividual>
    


