        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q46831"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q5783"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N38_VC_23_ES/event/ev8"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Interest_on_this_VC"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N38_VC_23_ES"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/37.947818301703926_-6.989911132846735"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/0"/>
        <ontology:hasDescription>There is a successful registration of a quality scheme that aims to retrieve Spanish autochthonous breeds. The Andalusian white goat is an endangered breed. It is adapted to meridional mountain areas, specially to the Andalusian mountain ranges where it grazes extensively producing various ecosystem services.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N38_VC_23_ES/event/ev8 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N38_VC_23_ES/event/ev8">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1061357"/>
