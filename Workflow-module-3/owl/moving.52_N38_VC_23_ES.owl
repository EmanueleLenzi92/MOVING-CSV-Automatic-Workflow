    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N38_VC_23_ES/event/ev1">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q10990"/>
