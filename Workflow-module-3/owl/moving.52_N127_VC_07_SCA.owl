    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N127_VC_07_SCA/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
