        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N213_VC_12_HU/event/ev3"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N213_VC_12_HU"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/47.355369444_17.88145"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Transdanubian mountains. The reference mountain landscape of this VC is Csesznek. Csesznek is a village in Veszprém County, Zirc district. It is located in the Bakony Mountains, 11 km north of Zirc. Csesznek is the pearl of the Bakony Mountains, where the visitors can choose active recreation or quiet relaxation in addition to the gastronomic eateries.  </ontology:hasDescription>
    </NamedIndividual>
    


