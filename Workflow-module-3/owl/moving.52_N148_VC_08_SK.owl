        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N148_VC_08_SK"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/49.027855986540146_20.340263390138666"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The total number of bed places (BPs) in tourist accommodations/year in the LAU (Local Administrative Unit) is 856. The regional (Region) share of total BPs/year is 0.69%. The number of agricultural holdings in the LAU is 3515. The nearest settlement with population over 100000 (km) is 108. In this region protected areas are not present.  </ontology:hasDescription>
    </NamedIndividual>
    


