        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q2007388"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q214"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q2827199"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q45108"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q697248"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7150699"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N148_VC_08_SK/event/ev8"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Interest_on_this_VC"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N148_VC_08_SK"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/49.058611111_19.889166666"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/2"/>
        <ontology:hasDescription>Specialized small-scale farming producing high-quality products. It is an adaptation of small farmers to the market by particular products. They cannot compete on the market with prominent producers and/or with productions located in better natural conditions for agriculture. One farm produces cold-pressed oils from Silybum marianum, Rapeseed oil, Hemp oil, Flax, and Poppy seeds. Another farm produces EU-certified organic hemp (in Východná, 775 m above sea), including manual harvesting and processing tincture. The farms have an e-shop, and products are sold in Slovakia. Production of new products in Slovak mountains is rare.  </ontology:hasDescription>
    </NamedIndividual>
    


