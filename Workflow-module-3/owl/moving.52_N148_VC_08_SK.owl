    <!-- https://dlnarratives.eu/narrative/N148_VC_08_SK/event/ev7 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N148_VC_08_SK/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1091679"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1575477"/>
