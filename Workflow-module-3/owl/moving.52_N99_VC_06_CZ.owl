        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q205961"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q646107"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Innovation"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N99_VC_06_CZ"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/49.399270301749844_13.305087540081216"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The type of innovation of this VC (Value Chain) is unspecified. The VC is considered a traditional, because it imeplements established farm practices. The innovation is related to the whole VC. The land use systems involved are The chicken husbandry does not rely on &amp;apos;land&amp;apos;, since the inputs are often transported to the farm. The VC rely available technology and skills of farmers. The local assets include Cultural.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N99_VC_06_CZ/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N99_VC_06_CZ/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
