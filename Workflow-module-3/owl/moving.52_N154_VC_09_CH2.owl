    <!-- https://dlnarratives.eu/narrative/N154_VC_09_CH2/event/ev1 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N154_VC_09_CH2/event/ev1">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q2376488"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q39"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q646107"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N154_VC_09_CH2/event/ev2"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Gruyère_is_a_typical_Swiss_cheese,_produced_in_the_mountain_pastures_in_summer"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N154_VC_09_CH2"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/47.07622849632307_6.905418684376097"/>
        <ontology:hasDescription>The MOVING reference member state of this VC (Value Chain) is SWITZERLAND 2. The reference MOVING Card ID of this VC is VC 09 CH2. Alpine Gruyère is produced seasonally from April to October in 53 alpine chalets. Gruyère production is organised by the Gruyère Interprofession created in 1997 who brings together milk producers, cheese makers and ripeners and thus guarantees the quality and identity of Gruyère.  </ontology:hasDescription>
    </NamedIndividual>
    


