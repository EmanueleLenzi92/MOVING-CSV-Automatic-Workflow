        <ontology:isAboutCountry rdf:resource="https://dlnarratives.eu/resource/Q39"/>
        <rdfs:label>Gruyère is a typical Swiss cheese, produced in the mountain pastures in summer</rdfs:label>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N154_VC_09_CH2/creation -->


