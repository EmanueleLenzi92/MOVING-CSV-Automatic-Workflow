        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.841439503312074_-3.7276281715434885"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/2"/>
        <ontology:hasDescription>The primary sector share of total employment/year [Province] is 3.74%. The secondary sector share of total employment/year [Province] is 15.20%. The tertiary sector share of total employment/year [Province] is 81.06%. The primary sector share of total employment/year [Region] is unspecified. The secondary sector share of total employment/year [Region] is unspecified. The tertiary sector share of total employment/year [Region] is unspecified.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev7 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1277907"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q165647"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q22855"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q2807"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q3214940"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q396338"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q467"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q2674120/participant"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q4539/participant"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev8"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Interest_on_this_VC"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.416944444_-3.703333333"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/0"/>
        <ontology:hasDescription>Succesfull place-based cooperative of women connected to the territory and engaged with local producers&amp;apos; networks; Use of organic and proximity ingredients and quality certification through &amp;apos;Participatory Guarantee System&amp;apos;. The brewery is a cooperative with equal participation, involvement and salary for each of the five women that own it. Appart from the hops project, they participate in Madrid Km 0, a coworking space to rethink and manage the stock, transport and delivery of agroecological products coming from the rural areas of the region to the city of Madrid. Around this project, different initiatives generate sinergies to access to markets and consumers from the city.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev8 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev8">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1277907"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q15284"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q174165"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q175185"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q219409"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q5119"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev9"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Challenges"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.841439503312074_-3.7276281715434885"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/2"/>
        <ontology:hasDescription>1) Access to the markets to reach also consumers from other municipalities and from the capital city; 2) Knitting networks of producers in times where rural areas have suffered a great depopulation and land abandonment. Overall the type of challenge faced by this VC is Current. This VC is classified as Innovative.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev9 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev9">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1148482"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1165944"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1553864"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q165647"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q214693"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q219416"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q3214940"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q3395383"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q576355"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q646107"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES/event/ev10"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Innovation"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N118_VC_07_ES"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/40.841439503312074_-3.7276281715434885"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/2"/>
        <ontology:hasDescription>The type of innovation of this VC (Value Chain) is Endogenous. Bailandera beer uses ingredients of proximity and organic and has a quality certification through a participatory guarantee system. Their compromise with the sustainability also reaches the machinery of the brewery, using recycled materials coming from other agroindustries and adapted to the brewery. In addition, their activity goes beyond the beer making as they are engaged in a project to retrieve and enhance the production of autochtonous varieties of hops. The innovation is related to New governance systems. The land use systems involved are Cropland. The local assets include Social.  </ontology:hasDescription>
    </NamedIndividual>
    


