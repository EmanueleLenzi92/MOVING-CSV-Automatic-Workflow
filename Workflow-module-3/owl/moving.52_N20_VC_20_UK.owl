        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N20_VC_20_UK"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/57.0_-5.0"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/3"/>
        <ontology:hasDescription>Other LAU1 areas strongly associated with adventure tourism and experience days in the UK include Lochaber (particularly the Nevis Range), Badenoch and Strathspey (based around Aviemore and Cairngorm), and Perth and Kinross (based around Dunkeld in the southern Highlands) in Scotland, and Gwynedd and Conwy (Snowdonia National Park) in Wales.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N20_VC_20_UK/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N20_VC_20_UK/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q11811449"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1428514"/>
