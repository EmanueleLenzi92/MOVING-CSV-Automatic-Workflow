        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N20_VC_20_UK"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/53.0_-1.0"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/0"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Cumbria (NUTS2). The reference mountain landscape of this VC is South Lakeland. South Lakeland is in the north-west of England and is partly within the Lake District National Park, an internationally renowned area for recreation and tourism. The area has a mixed landscape of mountains, hills, lakes, lowlands and coast and is accessible for large numbers of people in the north of England, with good road and rail links. Upland areas have a tradition of hill farming and sheep grazing, although the tourism industry is very important particularly in &amp;apos;honeypots&amp;apos;.  </ontology:hasDescription>
    </NamedIndividual>
    


