        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q39816"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q49389"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q8502"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N20_VC_20_UK/event/ev9"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Key_local_assets"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N20_VC_20_UK"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/54.312277760640605_-2.8312484360236083"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>Landscape features that support outdoor activities (including peaks, valleys, cliffs, gorges, lakes, caves, scree) and attract tourism markets (scenery); cultural knowledge associated with place and practice of mountain-based pursuits to support and commodify access for novice and tourism markets.   </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N20_VC_20_UK/event/ev9 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N20_VC_20_UK/event/ev9">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
