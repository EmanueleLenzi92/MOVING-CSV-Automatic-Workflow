        <ontology:hasDescription>This VC is present all along the Sierra Morena region, including the provinces (NUTS2) of Huelva, Seville, Córdoba and Jaén.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N63_VC_04_ES/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N63_VC_04_ES/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q104552567"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q128887"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1443790"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q156137"/>
