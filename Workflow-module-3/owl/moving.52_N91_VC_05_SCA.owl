        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q37813"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q82821"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev10"/>
