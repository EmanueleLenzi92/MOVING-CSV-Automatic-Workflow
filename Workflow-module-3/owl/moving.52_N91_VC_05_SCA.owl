        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q30121"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q345505"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q4421"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev3"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N91_VC_05_SCA"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/61.21800238534556_8.474623879406925"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/0"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Scandinavean Mountains - Scandes. The reference mountain landscape of this VC is Vang. The region is covered by water streams and forests in the low lands, where also pastures and crops are grown, while the higher areas are dominated by heather and alpine medaws for summer pastures. Its geography is very diverese as it changes with the altitude, which leads to multiple land uses and recreational assets during the four seasons.  </ontology:hasDescription>
    </NamedIndividual>
    


