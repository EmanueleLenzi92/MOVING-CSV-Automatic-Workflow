        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/0"/>
        <ontology:hasDescription>Besides having a big cultural component, this VC has an important role in the conservation of mountain pastures. The new product is related to the touristic asset of the VC while the marketing strategies are linked to the cooperation and development of regional brands and e-commerce platforms.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev8 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev8">
