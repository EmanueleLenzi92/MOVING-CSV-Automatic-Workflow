        <ontology:hasDescription>The VC is also present in other areas such as Nore og Uvdal (NO0633), Øystre Slidre (NO0544).  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q15041366"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q186547"/>
