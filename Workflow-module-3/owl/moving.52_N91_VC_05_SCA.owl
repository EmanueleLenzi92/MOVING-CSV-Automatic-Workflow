        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q30121"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q489357"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7937"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q8502"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N91_VC_05_SCA/event/ev9"/>
