        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q12560"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q170427"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q192384"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q23522"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q25469408"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q309343"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7809/participant"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N49_VC_25_SER/event/ev3"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N49_VC_25_SER"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/43.95_20.933333333"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Eastern Serbia, Balkan mountains region. The reference mountain landscape of this VC is Balkan mountains. The area of South Eastern Serbia, and town of Pirot are treasuring the tradition that comes from the Ottoman times. The sheep breeding slopes of Balkan mountains have been the source of high quality wool and the mastery of its dying and colouring and makign wonderful rags has been present till now. Pirot carpet is imaterial heritage protected by UNESCO and is highly valued at the very small niche market.  </ontology:hasDescription>
    </NamedIndividual>
    


