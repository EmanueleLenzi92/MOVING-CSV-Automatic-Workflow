        <equivalentProperty rdf:resource="https://dlnarratives.eu/ontology#hasSerialization"/>
    </DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#after -->


    <DatatypeProperty rdf:about="http://www.w3.org/2006/time#after">
        <equivalentProperty rdf:resource="https://dlnarratives.eu/ontology#after"/>
    </DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#before -->


    <DatatypeProperty rdf:about="http://www.w3.org/2006/time#before">
        <equivalentProperty rdf:resource="https://dlnarratives.eu/ontology#before"/>
    </DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDDate -->


    <DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDDate">
        <equivalentProperty rdf:resource="https://dlnarratives.eu/ontology#inXSDDate"/>
    </DatatypeProperty>
    


    <!-- http://www.w3.org/2011/content#chars -->


    <DatatypeProperty rdf:about="http://www.w3.org/2011/content#chars">
        <equivalentProperty rdf:resource="https://dlnarratives.eu/ontology#chars"/>
    </DatatypeProperty>
    


    <!-- https://dlnarratives.eu/ontology#asGML -->


    <DatatypeProperty rdf:about="https://dlnarratives.eu/ontology#asGML"/>
    


    <!-- https://dlnarratives.eu/ontology#asWKT -->


    <DatatypeProperty rdf:about="https://dlnarratives.eu/ontology#asWKT">
