    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N133_VC_08_BG/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q202904"/>
