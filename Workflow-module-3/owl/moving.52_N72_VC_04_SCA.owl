    <!-- https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev7 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev7">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1196234"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1503716"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q20"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q39809"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q484847"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev8"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Interest_on_this_VC"/>
