        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q431289"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q729"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q8094"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev9"/>
