        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/62.54139931467635_9.539715786324109"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>High quality product, which is part of the traditional Norwegian food culture. The VC continues in the region because the employees of the former cured meat company have continued with the business, adding new products and new marketing strategies. Mostly related to e-commerce.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev8 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N72_VC_04_SCA/event/ev8">
