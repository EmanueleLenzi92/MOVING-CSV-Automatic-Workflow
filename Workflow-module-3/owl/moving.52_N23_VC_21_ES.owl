    <!-- https://dlnarratives.eu/narrative/N23_VC_21_ES/event/ev1 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N23_VC_21_ES/event/ev1">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q29"/>
