        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q484847"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q646107"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q7860"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Innovation"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N109_VC_06_SCA"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/63.19999787741221_11.137046975164019"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The type of innovation of this VC (Value Chain) is Endogenous and Exogenous. This VC is focussed on keeping the nutrutional values of cereals as much as possible by doing granola. Granola is nowadays rarely done by hand, and this VC is even more unique as the use only local and organic products. In fact, the activity begun due to the lack of an organic Norwegian granola in the market. The product is sold in the store and is also available on the website (e-commerce). The innovation is related to New products and New marketing strategies. The land use systems involved are Cropland. The local assets include Natural, social and cultural.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N109_VC_06_SCA/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N109_VC_06_SCA/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
