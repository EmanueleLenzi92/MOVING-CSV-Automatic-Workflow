    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N314_VC_18_FR/event/ev1">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q142"/>
