    <!-- https://dlnarratives.eu/narrative/N314_VC_18_FR/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N314_VC_18_FR/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/valorisation_event"/>
        <rdf:type rdf:resource="https://dlnarratives.eu/ontology#Event"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q1087803"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q14112"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q3247399"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q40104"/>
        <ontology:isPresentedBefore rdf:resource="https://dlnarratives.eu/narrative/N314_VC_18_FR/event/ev3"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Mountain_landscape_and_reference_chains"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N314_VC_18_FR"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/41.923888888_8.823888888"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/1"/>
        <ontology:hasDescription>The reference mountain chain of this VC is Corsican moutains. The reference mountain landscape of this VC is Celavu - Prunelli. The Prunelli Valley is the most important valley of Monte Renosu (2352 m). Strongly dug, it shelters few villages including those of apple production (Basterga and Todda). The strong human deprivation of the villages is compensated by a relative proximity to the city of Aiacciu. It is the old winter pastoral localities which are today the most populated, in particular because of a very strong urban and tourist attraction (Bastelicaccia and Purtichju).  </ontology:hasDescription>
    </NamedIndividual>
    


