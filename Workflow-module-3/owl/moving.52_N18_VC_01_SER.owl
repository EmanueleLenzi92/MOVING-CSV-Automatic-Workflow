        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q403"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q4112083"/>
        <ontology:hasEntity rdf:resource="https://dlnarratives.eu/resource/Q994217"/>
        <ontology:is_identified_by rdf:resource="https://dlnarratives.eu/appellation/Concluding_remarks"/>
        <ontology:partOfNarrative rdf:resource="https://dlnarratives.eu/narrative/N18_VC_01_SER"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/phenomenal_place/42.766667_19.216667"/>
        <ontology:took_place_at rdf:resource="https://dlnarratives.eu/place/3"/>
        <ontology:hasDescription>VC is present in Montenegro, since there are farmers in both bordering regions that have pastures in both countries. Additionally, the tradition and cultural heritage is strongly connected to the cross-border region (Serbia and Montenegro, as well as Serbia and Albania). The same type of product / Dry sheep meat (Sjenica stelja) is protected in Montenegro as Montenegrin stelja.  </ontology:hasDescription>
    </NamedIndividual>
    


    <!-- https://dlnarratives.eu/narrative/N18_VC_01_SER/event/ev2 -->


    <NamedIndividual rdf:about="https://dlnarratives.eu/narrative/N18_VC_01_SER/event/ev2">
        <rdf:type rdf:resource="https://dlnarratives.eu/event-type/natural_event"/>
