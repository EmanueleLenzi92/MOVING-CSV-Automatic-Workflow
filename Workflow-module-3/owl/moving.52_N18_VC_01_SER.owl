        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- https://dlnarratives.eu/ontology#hasSerialization -->


    <DatatypeProperty rdf:about="https://dlnarratives.eu/ontology#hasSerialization"/>
    


